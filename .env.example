# concierge.studio — env vars (copy to .env.local for dev)
#
# Mode column per ref 7 SOP:
#   B = build-time inlined (NEXT_PUBLIC_*)  → rotation needs redeploy
#   R = runtime binding (Cloudflare vars)   → rotation visible immediately
#
# Build-time (Next.js inlines at build):

NEXT_PUBLIC_SITE_URL=https://concierge.studio                    # B
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=                                    # B (optional; leave blank to disable analytics)
NEXT_PUBLIC_BASE_URL=https://concierge.studio                    # B (used by /status sentinel)
NEXT_PUBLIC_BUILD_SHA=                                           # B (set by CI from $GITHUB_SHA)
NEXT_PUBLIC_BUILD_TIME=                                          # B (set by CI)

# Runtime (Cloudflare Pages env vars / wrangler [vars]):

ADMIN_USER=admin                                                  # R
ADMIN_PASSWORD=change-me-on-first-deploy                          # R
ADMIN_OWNER_EMAILS=seb.aquilina@gmail.com                         # R

ANTHROPIC_API_KEY=sk-ant-...                                      # R
RESEND_API_KEY=re_...                                             # R

# Optional:
SENTRY_AUTH_TOKEN=                                                # R (CI only)
SENTRY_DSN=                                                       # R
