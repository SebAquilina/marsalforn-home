{
  "name": "marsalforn-home-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "audit": "tsx scripts/audit.ts",
    "audit:static": "tsx scripts/audit-static.ts ../..",
    "validate:seed": "tsx scripts/validate-content.ts",
    "seed:pricing": "tsx scripts/seed-pricing.ts",
    "deploy": "next build && npx @cloudflare/next-on-pages@latest && wrangler pages deploy .vercel/output/static --project-name=concierge-studio-web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:zod-seed": "tsx scripts/validate-seed.ts",
    "seed:coverage": "tsx scripts/seed-coverage.ts",
    "audit:network": "tsx scripts/audit.ts",
    "audit:secrets": "bash scripts/audit/audit-secrets.sh",
    "audit:route-integrity": "bash scripts/audit/audit-route-integrity.sh",
    "audit:analytics": "tsx scripts/audit-analytics/run.ts",
    "audit:analytics-runtime": "tsx scripts/audit-analytics/runtime.test.ts",
    "test:unit": "vitest run tests/unit",
    "audit:brand-assets": "bash scripts/audit/audit-brand-assets.sh"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.0",
    "next": "14.2.15",
    "next-mdx-remote": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240924.0",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.24.2",
    "drizzle-orm": "^0.33.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "wrangler": "^3.78.0",
    "vitest": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "@playwright/test": "^1.49.0"
  }
}
